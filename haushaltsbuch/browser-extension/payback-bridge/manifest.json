{
  "manifest_version": 3,
  "name": "HydraHive PAYBACK Bridge",
  "version": "1.0.2",
  "description": "Erfasst manuell sichtbare PAYBACK-Daten und sendet sie mit einem Einmalcode an HydraHive.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.payback.de/*"],
  "optional_host_permissions": ["https://*/*", "http://localhost/*", "http://127.0.0.1/*"],
  "action": {
    "default_title": "PAYBACK für HydraHive erfassen",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.payback.de/*"],
      "js": ["content-utils.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
